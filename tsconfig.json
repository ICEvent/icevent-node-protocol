{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "core/**/*.ts",
    "templates/**/*.ts",
    "canisters/**/*.ts",
    "indexer/**/*.ts",
    "sdk/**/*.ts",
    "examples/**/*.ts",
    "tests/**/*.ts"
  ]
}
